{
  "name": "ESP8266 OLED Screensaver",
  "dockerFile": "Dockerfile",
  "context": ".",
  "remoteUser": "vscode",

  "features": {},

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cpp-devtools",
        "ms-vscode.cpptools-themes",
        "twxs.cmake",
        "ms-vscode.cmake-tools",
        "ms-vscode.vscode-serial-monitor",
        "platformio.platformio-ide",
        "clangd.clangd",
        "xaver.clang-format",
        "eamodio.gitlens",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        "github.vscode-pull-request-github",
        "github.vscode-github-actions",
        "ms-python.python",
        "ms-python.debugpy",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "humao.rest-client",
        "DavidAnson.vscode-markdownlint",
        "pkief.material-icon-theme",
        "anthropic.claude-code",
        "andrepimenta.claude-code-chat",
        "github.copilot-chat",
        "continue.continue",
        "google.geminicodeassist",
        "danielsanmedium.dscodegpt"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": false,
        "python.formatting.provider": "black",
        "[cpp]": {
          "editor.defaultFormatter": "xaver.clang-format",
          "editor.formatOnSave": true,
          "editor.rulers": [100]
        },
        "[h]": {
          "editor.defaultFormatter": "xaver.clang-format",
          "editor.formatOnSave": true,
          "editor.rulers": [100]
        },
        "[markdown]": {
          "editor.formatOnSave": true
        },
        "C_Cpp.default.intelliSenseEngine": "Tag Parser",
        "C_Cpp.intelliSenseEngineMaxCacheSize": 16,
        "clang-format.style": "google",
        "clang-format.fallbackStyle": "Google",
        "files.exclude": {
          "**/.pio": true,
          "**/build": true,
          "**/.git": true
        }
      }
    }
  },

  "postCreateCommand": "pre-commit install && platformio update && pip3 install -q -e . 2>/dev/null || true",

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.local/bin"
  },

  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh,target=/home/vscode/.config/gh,type=bind,consistency=cached"
  ],

  "forwardPorts": [80, 23],
  "portsAttributes": {
    "80": {
      "label": "HTTP Server",
      "onAutoForward": "notify"
    },
    "23": {
      "label": "Telnet Console",
      "onAutoForward": "notify"
    }
  }
}
